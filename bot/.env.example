# Copy this file to ".env" and fill in your values.  NEVER commit the real .env.
# The bot reads these as environment variables.

# ---- Kraken Futures API keys (create at futures.kraken.com -> Settings -> API Keys)
# For the DEMO/testnet, create keys at demo-futures.kraken.com instead.
# Give the key TRADING permission only.  DO NOT enable withdrawals.  IP-whitelist it.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ---- Safety switches (leave these as-is until you have proven the bot on demo) ----
DRY_RUN=true          # true = log intended orders, place nothing. Set false to actually trade.
USE_DEMO=true         # true = Kraken Futures demo (fake money). Set false ONLY for real money.

# ---- Strategy / risk ----
# Defaults below make the bot size trades EXACTLY like the dashboard's AI account:
# deploy 10-80% of equity as margin by confidence, solve leverage per trade to risk
# ~2-4% (hard cap 6%), with a per-market leverage ceiling (BTC 40x/ETH 25x/SOL 20x).
SYMBOLS=BTC,ETH,SOL   # base coins; the bot resolves the real perp symbol per exchange
DATA_SOURCE=binance   # where CHART DATA comes from: "binance" (live, what you asked for)
                      # or "kraken". Falls back to kraken automatically if Binance is
                      # unreachable on your network.
TIMEFRAMES=15m,1h,4h,1d
# STRATEGY: "reversion" (default) = buy PROVEN bullish reversal candlestick patterns
#   (hammer, bullish engulfing, tweezer...) only when oversold/stretched-down, and
#   short bearish reversals only when overbought — i.e. buy big dips / sell big spikes,
#   and NEVER fade a move with no reversal candle (won't catch a falling knife).
#   "momentum" = the old trend-following score (kept for comparison).
STRATEGY=reversion
# TRIGGER only applies to the "momentum" strategy:
#   "standard" = signals score >=18 · "strong" = only score >=45.
TRIGGER=standard
EXIT_STYLE=hard       # "hard" = real stop losses (recommended). "diamond" = hold through drawdown (risky).

# Leverage ceilings per coin (BASE:MAX,...). The bot uses the LEAST leverage needed
# to hit the risk band, never more than this. Leave blank to use the built-in map.
MAX_LEVERAGE_MAP=BTC:40,ETH:25,SOL:20,HYPE:5
MAX_LEVERAGE=0        # 0 = trust the per-market map. >0 = extra HARD cap over ALL coins (use e.g. 3 for cautious real money).

# Risk band: fraction of equity lost if a trade hits its stop, scaled by confidence.
RISK_MIN_FRAC=0.02    # ~2% at the confidence floor
RISK_MAX_FRAC=0.04    # ~4% when very confident
RISK_CAP_FRAC=0.06    # never risk more than 6% on one trade

MAX_INVEST_FRAC=0.80  # max margin per trade (fraction of equity)
MAX_DEPLOY_FRAC=0.80  # max total margin deployed at once
MAX_CONCURRENT=2
MIN_CONFIDENCE=63     # confidence floor. Lower (58) = more trades, higher (68) = pickier.
DAILY_LOSS_LIMIT=0.10 # stop opening trades after -10% in a day (kill-switch)

# ---- Backtest realism (so the "is this profitable" check isn't fake) ----
# The pre-trade backtest subtracts these real costs and also checks the edge still
# holds on the most recent (out-of-sample) third of history it hasn't traded.
FEE_RATE=0.0005      # taker fee per side (Kraken Futures ~0.05%)
SLIPPAGE=0.0002      # assumed slippage per side (~0.02%)
FUNDING_DAILY=0.0003 # average funding paid per day a position is held (~0.03%/day)
POLL_SECONDS=60

# ---- Live web monitor (served on your own machine only) ----
WEB_ENABLED=true      # open a local dashboard while the bot runs
WEB_HOST=127.0.0.1    # localhost only — do NOT change unless you know what you're doing
WEB_PORT=8899         # then open http://localhost:8899 in your browser (8787 left free for your other app)
